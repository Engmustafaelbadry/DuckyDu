[Unit]
Description=Raspberry Pi Kiosk Launcher
After=network-online.target systemd-user-sessions.service
Wants=network-online.target

[Service]
User=__APP_USER__
Group=__APP_USER__
Environment=HOME=/home/__APP_USER__
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
StandardInput=tty
StandardOutput=journal
StandardError=journal
ExecStart=/usr/bin/xinit /usr/local/bin/start-kiosk.sh -- :0 vt1 -keeptty -nolisten tcp
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
